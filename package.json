{
  "name": "whatsapp-electron",
  "productName": "WhatsApp",
  "version": "1.1.1",
  "description": "Unofficial WhatsApp Web desktop wrapper for Linux with voice and video calls",
  "author": {
    "name": "Dominik Lübben",
    "email": "dominikluebben@googlemail.com"
  },
  "private": true,
  "main": "src/main.js",
  "license": "GPL-2.0-or-later",
  "homepage": "https://github.com/DomiLuebben/whatsapp-electron#readme",
  "bugs": {
    "url": "https://github.com/DomiLuebben/whatsapp-electron/issues"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/DomiLuebben/whatsapp-electron.git"
  },
  "engines": {
    "node": ">=22.12 <26"
  },
  "scripts": {
    "check:node": "node scripts/check-node.js",
    "prestart": "npm run check:node",
    "start": "electron .",
    "test": "node --test",
    "prebuild": "npm run check:node",
    "build": "electron-builder --linux AppImage --publish never",
    "prebuild:deb": "npm run check:node",
    "build:deb": "electron-builder --linux deb --x64 --publish never",
    "prebuild:rpm": "npm run check:node",
    "build:rpm": "electron-builder --linux rpm --x64 --publish never",
    "prebuild:linux": "npm run check:node",
    "build:linux": "electron-builder --linux AppImage deb rpm --x64 --publish never",
    "prebuild:dir": "npm run check:node",
    "build:dir": "electron-builder --linux dir --publish never"
  },
  "devDependencies": {
    "electron": "^43.1.1",
    "electron-builder": "^26.11.1"
  },
  "build": {
    "appId": "com.dluebben.whatsapp-desktop",
    "productName": "WhatsApp",
    "asar": true,
    "compression": "maximum",
    "electronFuses": {
      "runAsNode": false,
      "enableNodeOptionsEnvironmentVariable": false,
      "enableNodeCliInspectArguments": false,
      "onlyLoadAppFromAsar": true,
      "grantFileProtocolExtraPrivileges": false
    },
    "electronLanguages": [
      "de",
      "en-US"
    ],
    "directories": {
      "output": "dist",
      "buildResources": "build"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "category": "Network;InstantMessaging;",
      "icon": "build/icon.png",
      "maintainer": "Dominik Lübben <dominikluebben@googlemail.com>",
      "vendor": "Dominik Lübben",
      "synopsis": "WhatsApp Web Desktop",
      "description": "Unofficial WhatsApp Web desktop wrapper with tray integration, native notifications, and voice/video calls.",
      "executableName": "whatsapp",
      "desktop": {
        "entry": {
          "Name": "WhatsApp",
          "Comment": "WhatsApp Web Desktop",
          "StartupWMClass": "WhatsApp"
        }
      }
    },
    "appImage": {
      "artifactName": "WhatsApp-${version}-x86_64.AppImage"
    },
    "deb": {
      "artifactName": "whatsapp-electron-${version}-amd64.deb",
      "packageCategory": "net",
      "depends": [
        "libgtk-3-0t64 | libgtk-3-0",
        "libnotify4",
        "libnss3",
        "libxss1",
        "libxtst6",
        "xdg-utils",
        "libatspi2.0-0t64 | libatspi2.0-0",
        "libuuid1",
        "libsecret-1-0"
      ],
      "recommends": [
        "libayatana-appindicator3-1 | libappindicator3-1"
      ]
    },
    "rpm": {
      "artifactName": "whatsapp-electron-${version}-x86_64.rpm",
      "packageCategory": "Applications/Internet"
    }
  }
}
